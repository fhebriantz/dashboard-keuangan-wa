# Supabase (server-only — JANGAN pakai prefix NEXT_PUBLIC_ untuk service role)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service_role key, bypass RLS, rahasia!

# Untuk dashboard (boleh dibaca client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Secret bersama yang dikirim WA Gateway di header "x-webhook-secret"
WA_WEBHOOK_SECRET=ganti-dengan-string-acak-panjang

# Password untuk masuk halaman admin (/admin)
ADMIN_PASSWORD=ganti-dengan-password-kuat

# Alamat publik aplikasi (untuk link laporan yang dikirim bot).
# Contoh: https://dashboard-keuangan-wa.vercel.app  (tanpa garis miring akhir)
APP_URL=

# Balas nomor yang TIDAK terdaftar? false = diam (hemat kuota, default).
# true = kirim "Nomor Anda belum terdaftar..." (boros kuota, tapi menyapa calon pelanggan)
REPLY_TO_UNREGISTERED=false

# (Opsional) rahasia untuk endpoint /api/keep-alive. Kalau di-set, Vercel Cron
# otomatis mengirimnya; request lain tanpa secret ditolak.
CRON_SECRET=

# (Opsional) AI cadangan — hanya dipakai saat rule-based gagal, dan otomatis
# balik ke rule-based kalau limit/error. Kosongkan = MATI (murni rule-based).
# Pakai akun PRIBADI (bukan kantor). Contoh: Google Gemini free tier.
AI_PROVIDER=            # kosong = mati; isi "gemini" untuk aktif
GEMINI_API_KEY=         # kunci pribadi dari aistudio.google.com
GEMINI_MODEL=gemini-flash-lite-latest
# (Opsional) rantai model — kalau model kena limit/sibuk, otomatis coba
# berikutnya. Dipisah koma. Kosongkan untuk pakai default bawaan.
GEMINI_MODELS=

# Provider balasan WA:
#   response = balasan dikembalikan di HTTP response (gateway yang kirim)
#   fonnte   = kirim aktif via API Fonnte (pakai ini kalau gateway = Fonnte)
#   cloud    = kirim aktif via WhatsApp Cloud API resmi (Meta)
WA_PROVIDER=fonnte

# Hanya diisi jika WA_PROVIDER=fonnte (token device dari dashboard Fonnte)
FONNTE_TOKEN=

# Hanya diisi jika WA_PROVIDER=cloud
WA_CLOUD_TOKEN=
WA_CLOUD_PHONE_ID=
