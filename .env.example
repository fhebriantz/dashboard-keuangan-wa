# Supabase (server-only — JANGAN pakai prefix NEXT_PUBLIC_ untuk service role)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service_role key, bypass RLS, rahasia!

# Untuk dashboard (boleh dibaca client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Secret bersama yang dikirim WA Gateway di header "x-webhook-secret"
WA_WEBHOOK_SECRET=ganti-dengan-string-acak-panjang

# Provider balasan WA:
#   response = TRIAL (gratis) — balasan dikirim gateway via HTTP response
#   cloud    = PRODUKSI — kirim aktif via WhatsApp Cloud API resmi (Meta)
WA_PROVIDER=response

# Hanya diisi jika WA_PROVIDER=cloud
WA_CLOUD_TOKEN=
WA_CLOUD_PHONE_ID=
